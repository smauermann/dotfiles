[core]
    excludesfile = /Users/stephan/.gitignore_global
[filter "hawser"]
    clean = git hawser clean %f
    smudge = git hawser smudge %f
    required = true
[filter "lfs"]
    clean = git lfs clean %f	
    smudge = git lfs smudge %f	
    required = true
[push]
    default = simple
[init]
	  defaultBranch = main
[includeIf "gitdir:~/projects/github.com/"]
    path = ~/projects/github.com/.gitconfig
[includeIf "gitdir:~/projects/git.deepl.dev/"]
    path = ~/projects/git.deepl.dev/.gitconfig
